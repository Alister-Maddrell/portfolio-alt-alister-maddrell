---
import '../styles/global.css';
import palettes from '../data/palettes.json';

const projects = [
  {
    id: 'hartley',
    title: 'Hartley',
    description: 'Emergency-focused trade website with 24/7 lead capture, click-to-call, and service area mapping that converts urgent searches into booked jobs.',
    url: 'https://demo-hartley-plumbing.vercel.app',
    pages: ['/#services', '/', '/#contact'],
    image: '/thumbnails/hartley.webp',
    image2: '/thumbnails/hartley-2.webp',
    image3: '/thumbnails/hartley-3.webp',
  },
  {
    id: 'kin',
    title: 'Kin',
    description: 'Warm editorial hospitality site with interactive digital menu, event listings, email capture, and catering enquiries — a community hub that drives repeat visits.',
    url: 'https://demo-kin-grain-cafe.vercel.app',
    pages: ['/#menu', '/', '/#contact'],
    image: '/thumbnails/cafe.webp',
    image2: '/thumbnails/cafe-2.webp',
    image3: '/thumbnails/cafe-3.webp',
  },
  {
    id: 'apex',
    title: 'Apex',
    description: 'Conversion-optimised fitness site built as a sales funnel — multi-step lead capture, membership pricing, and urgency-driven CTAs that turn visitors into trial members.',
    url: 'https://demo-apex-fitness.vercel.app',
    pages: ['/#classes', '/', '/#contact'],
    image: '/thumbnails/fitness.webp',
    image2: '/thumbnails/fitness-2.webp',
    image3: '/thumbnails/fitness-3.webp',
  },
  {
    id: 'whitfield',
    title: 'Whitfield',
    description: 'Authority-driven professional services site with insights blog, consultation booking, animated credibility metrics, and content marketing architecture.',
    url: 'https://demo-whitfield-accounting.vercel.app',
    pages: ['/#insights', '/', '/#contact'],
    image: '/thumbnails/accounting.webp',
    image2: '/thumbnails/accounting-2.webp',
    image3: '/thumbnails/accounting-3.webp',
  },
  {
    id: 'luma',
    title: 'LUMA',
    description: 'Luxury appointment-based site with a full booking flow, expandable service menu, transformation gallery, and team showcase — replacing phone bookings with digital elegance.',
    url: 'https://demo-luma-hair-beauty.vercel.app',
    pages: ['/#services', '/', '/#book'],
    image: '/thumbnails/hair.webp',
    image2: '/thumbnails/hair-2.webp',
    image3: '/thumbnails/hair-3.webp',
  },
].map(p => ({
  ...p,
  bg: palettes[p.id].background,
  accent: palettes[p.id].accent,
  text: palettes[p.id].text,
}));

// Hero and contact get their own palette
const heroBg = '#2B4F5B';
const heroAccent = '#E8C4A0';
const contactBg = '#2B4A3E';
const contactAccent = '#D4B0C8';

const bgColors = [heroBg, ...projects.map(p => p.bg), contactBg];
const accentColors = [heroAccent, ...projects.map(p => p.accent), contactAccent];

const navItems = [
  { label: 'Home', slideIndex: 0 },
  ...projects.map((p, i) => ({ label: p.title, slideIndex: i + 1 })),
  { label: 'Contact', slideIndex: 6 },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Alister Maddrell — Web Designer & Developer based in Sydney. Custom-built, high-performance websites for local businesses." />
    <meta property="og:title" content="Alister Maddrell — Web Designer & Developer" />
    <meta property="og:description" content="Custom-built, high-performance websites for Sydney businesses." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/thumbnails/hartley.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href="https://portfolio-alt-alister-maddrell.vercel.app/" />
    <title>Alister Maddrell — Web Designer & Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <div id="app" class="relative w-full h-screen overflow-hidden">
      <!-- ═══════════════════════════════════════ -->
      <!-- BACKGROUND LAYER                       -->
      <!-- ═══════════════════════════════════════ -->
      <div id="bg-layer" class="absolute inset-0" style={`background-color: ${heroBg};`}></div>

      <!-- ═══════════════════════════════════════ -->
      <!-- FIXED HEADER — always visible          -->
      <!-- ═══════════════════════════════════════ -->
      <header id="app-header" class="absolute top-0 left-0 w-full h-[90px] pr-[6.25%] pl-[calc(6.25%+16px)] flex items-center justify-between z-30 transition-colors duration-600" style={`color: ${heroAccent};`}>
        <a href="#" class="ui-text ui-text-sm flex items-center min-h-[44px]" data-slide="0">Alister Maddrell</a>
        <a href="#" class="ui-text ui-text-sm hover:opacity-70 transition-opacity duration-200 flex items-center min-h-[44px]" data-slide="6">Contact</a>
      </header>

      <!-- ═══════════════════════════════════════ -->
      <!-- SLIDE 0: HERO                          -->
      <!-- ═══════════════════════════════════════ -->
      <section id="slide-0" class="slide mounted active" style={`--slide-accent: ${heroAccent};`}>
        <div class="accent-bar" style={`background-color: ${heroAccent};`}></div>
        <div class="flex flex-col items-center justify-center h-full pt-[90px] px-[6.25%] text-center relative">
          <!-- Role label -->
          <p class="ui-text ui-text-sm text-white slide-desc" style="letter-spacing: 3px; opacity: 0.7;">Web Designer &amp; Developer · Sydney</p>

          <!-- Name — massive, center statement, accent colour -->
          <div class="relative mt-4 slide-title">
            <h1 id="hero-title-solid" class="hero-name title-solid" style={`color: ${heroAccent};`}></h1>
            <div id="hero-title-outline" class="hero-name title-outline absolute inset-0" style={`-webkit-text-stroke-color: ${heroAccent};`} aria-hidden="true"></div>
          </div>

          <!-- Project preview strip -->
          <div class="hero-preview-strip slide-image mt-8 lg:mt-10">
            {projects.map((project, i) => (
              <button class="hero-card card-work" data-slide={i + 1} style={`--card-color: ${heroAccent};`}>
                <div class="card-work-topbar card-work-topbar--mini">
                  <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                  </span>
                  <div class="card-work-urlbar card-work-urlbar--mini">
                    <span class="card-work-url">{project.title}</span>
                  </div>
                </div>
                <div class="card-work-img">
                  <img
                    src={project.image}
                    alt={`${project.title} preview`}
                    width="400"
                    height="248"
                    loading="eager"
                    decoding="async"
                  />
                </div>
              </button>
            ))}
          </div>

          <!-- CTAs -->
          <div class="flex gap-8 mt-8 slide-cta">
            <a href="#" class="hero-cta-primary ui-text ui-text-md" data-slide="1" style={`background: ${heroAccent}; color: #1a1a1a;`}>
              <span>View My Work</span>
              <span class="cta-arrow">&rarr;</span>
            </a>
            <a href="#" class="cta-link ui-text ui-text-md text-white" data-slide="6">
              <span>Get in Touch</span>
              <span class="cta-arrow">&rarr;</span>
            </a>
          </div>

          <!-- Scroll indicator -->
          <button class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-indicator text-white slide-bubble cursor-pointer bg-transparent border-none p-2 rounded-full transition-all duration-200 hover:bg-white/10 hover:scale-110 hover:shadow-[0_0_0_1px_rgba(255,255,255,0.1)]" data-slide="1" aria-label="Scroll to projects">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 5v14M5 12l7 7 7-7" />
            </svg>
          </button>
        </div>
      </section>

      <!-- ═══════════════════════════════════════ -->
      <!-- SLIDES 1-5: PROJECTS                   -->
      <!-- ═══════════════════════════════════════ -->
      {projects.map((project, i) => {
        const slideIndex = i + 1;
        return (
          <section id={`slide-${slideIndex}`} class="slide" data-slide-index={slideIndex} style={`--slide-accent: ${project.accent};`}>
            <!-- Accent bar -->
            <div class="accent-bar" style={`background-color: ${project.accent};`}></div>

            <div class="showcase-layout" style={`color: ${project.text};`}>
              <!-- Left column: content + live preview, evenly spaced -->
              <div class="showcase-left">
                <div class="showcase-content">
                  <h2 class="title-display title-project slide-title" style={`color: ${project.accent};`}>
                    {project.title}
                  </h2>
                  <p class="desc-text mt-6 slide-desc">
                    {project.description}
                  </p>
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="cta-link ui-text ui-text-md mt-[34px] slide-cta"
                    style={`color: ${project.accent};`}
                  >
                    <span>View Live Site</span>
                    <span class="cta-arrow">&rarr;</span>
                  </a>
                </div>
                <div class="live-preview hidden lg:block" style={`--card-color: ${project.accent}; border-color: ${project.accent};`}>
                  <div class="card-work-topbar card-work-topbar--mini">
                    <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                      <span></span><span></span><span></span>
                    </span>
                    <div class="card-work-urlbar card-work-urlbar--mini">
                      <span class="card-work-url">{project.title}</span>
                    </div>
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="card-work-capsule card-work-capsule--mini" aria-label={`Visit ${project.title}`}>
                      <svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6.66667M12 4V9.33333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                  </div>
                  <div class="live-preview-viewport">
                    <iframe
                      class="live-preview-iframe"
                      data-base-url={project.url}
                      data-pages={JSON.stringify(project.pages)}
                      src={`${project.url}?preview`}
                      title={`${project.title} live preview`}
                      loading="eager"
                      sandbox="allow-scripts allow-same-origin"
                    ></iframe>
                  </div>
                </div>
              </div>

              <!-- Center: Stacked screenshots -->
              <div class="showcase-cards slide-image" style="perspective: 800px;">
                <div class="showcase-stack" style={`--card-color: ${project.accent};`}>
                  <!-- Page 2 (top slot) -->
                  <div class="showcase-frame">
                    <div class="card-work-topbar card-work-topbar--mini">
                      <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                        <span></span><span></span><span></span>
                      </span>
                      <div class="card-work-urlbar card-work-urlbar--mini">
                        <span class="card-work-url">{project.title}</span>
                      </div>
                    </div>
                    <div class="card-work-img">
                      <img src={project.image2} alt={`${project.title} page 2`} width="1440" height="900" loading="eager" decoding="async" />
                    </div>
                  </div>
                  <!-- Landing page (center slot, flush) -->
                  <div class="showcase-frame">
                    <div class="card-work-topbar card-work-topbar--mini">
                      <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                        <span></span><span></span><span></span>
                      </span>
                      <div class="card-work-urlbar card-work-urlbar--mini">
                        <span class="card-work-url">{project.title}</span>
                      </div>
                      <a href={project.url} target="_blank" rel="noopener noreferrer" class="card-work-capsule card-work-capsule--mini" aria-label={`Visit ${project.title}`}>
                        <svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6.66667M12 4V9.33333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                    </div>
                    <div class="card-work-img">
                      <img src={project.image} alt={`${project.title} homepage`} width="1440" height="900" loading="eager" decoding="async" />
                    </div>
                  </div>
                  <!-- Page 3 (bottom slot) -->
                  <div class="showcase-frame">
                    <div class="card-work-topbar card-work-topbar--mini">
                      <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                        <span></span><span></span><span></span>
                      </span>
                      <div class="card-work-urlbar card-work-urlbar--mini">
                        <span class="card-work-url">{project.title}</span>
                      </div>
                    </div>
                    <div class="card-work-img">
                      <img src={project.image3} alt={`${project.title} page 3`} width="1440" height="900" loading="eager" decoding="async" />
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </section>
        );
      })}

      <!-- ═══════════════════════════════════════ -->
      <!-- SLIDE 6: ABOUT / CONTACT               -->
      <!-- ═══════════════════════════════════════ -->
      <section id="slide-6" class="slide" data-slide-index="6" style={`--slide-accent: ${contactAccent};`}>
        <div class="accent-bar" style={`background-color: ${contactAccent};`}></div>
        <div class="flex flex-col lg:flex-row h-full pt-[90px] relative">
          <!-- Left: Decorative monogram -->
          <div class="hidden lg:flex w-1/2 items-center justify-center overflow-hidden relative am-monogram" aria-hidden="true"></div>

          <!-- Right: Content -->
          <div class="w-full lg:w-1/2 flex flex-col justify-center px-[6.25%] lg:pr-[6.25%] lg:pl-0 py-8">
            <h2 class="title-display slide-title" style={`font-size: clamp(32px, 5vw, 90px); color: ${contactAccent};`}>
              Let's Work Together
            </h2>
            <p class="desc-text text-white mt-6 slide-desc">
              I design and build fast, modern websites for local businesses across Sydney. Every site is custom-built, SEO-optimised, and designed to turn visitors into customers.
            </p>

            <div class="mt-8 slide-cta">
              <a href="mailto:alistermaddrell@gmail.com" class="cta-link ui-text ui-text-md" style={`color: ${contactAccent};`}>
                <span>alistermaddrell@gmail.com</span>
                <span class="cta-arrow">&rarr;</span>
              </a>
              <p class="text-white text-sm mt-2">Sydney, Australia</p>
            </div>

            <!-- Contact form -->
            <form action="https://formspree.io/f/placeholder" method="POST" class="mt-10 space-y-5 max-w-[480px] slide-meta">
              <div>
                <label for="name" class="ui-text text-xs text-white block mb-1" style="letter-spacing: 1px;">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white text-base font-body focus:outline-none focus:border-white/30 transition-colors"
                />
              </div>
              <div>
                <label for="email" class="ui-text text-xs text-white block mb-1" style="letter-spacing: 1px;">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white text-base font-body focus:outline-none focus:border-white/30 transition-colors"
                />
              </div>
              <div>
                <label for="message" class="ui-text text-xs text-white block mb-1" style="letter-spacing: 1px;">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white text-base font-body focus:outline-none focus:border-white/30 transition-colors resize-none"
                ></textarea>
              </div>
              <button
                type="submit"
                class="ui-text ui-text-md bg-white text-black px-8 py-3 rounded hover:bg-white/80 hover:scale-[1.02] transition-all duration-200 cursor-pointer"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════ -->
      <!-- UNIFIED SLIDE NAV                      -->
      <!-- ═══════════════════════════════════════ -->
      <nav id="slide-nav" class="slide-nav z-40 transition-opacity duration-500 text-white" style="display: none;">
        <div class="slide-nav-inner">
          {navItems.map((item, i) => (
            <button class="slide-nav-item" data-slide={item.slideIndex}>
              <span class="slide-nav-label">{item.label}</span>
              <span class="slide-nav-dot"></span>
            </button>
          ))}
        </div>
      </nav>
    </div>

    <!-- ═══════════════════════════════════════ -->
    <!-- CLIENT-SIDE JS                         -->
    <!-- ═══════════════════════════════════════ -->
    <script define:vars={{ bgColors, accentColors }}>
      // ─── State ───
      let currentSlide = 0;
      const totalSlides = 7;
      let isTransitioning = false;
      const TRANSITION_LOCK_MS = 1200;

      // ─── DOM refs ───
      const bgLayer = document.getElementById('bg-layer');
      const appHeader = document.getElementById('app-header');
      const slideNav = document.getElementById('slide-nav');
      const slideNavItems = document.querySelectorAll('#slide-nav .slide-nav-item');

      // ─── Go to slide ───
      function goToSlide(index) {
        if (isTransitioning || index === currentSlide || index < 0 || index >= totalSlides) return;
        isTransitioning = true;
        hoverEnabled = false; // Disable hover during transition

        const prevSlide = document.getElementById(`slide-${currentSlide}`);
        const nextSlide = document.getElementById(`slide-${index}`);
        const prevIndex = currentSlide;

        // Stop scroll on outgoing slide, reset and start on incoming slide
        if (prevSlide && prevSlide._leaveCarousel) prevSlide._leaveCarousel();
        if (nextSlide && nextSlide._resetCarousel) nextSlide._resetCarousel();

        // Mount new slide (display: block), then after a frame fade it in
        if (nextSlide) {
          nextSlide.classList.add('mounted');
          requestAnimationFrame(() => {
            nextSlide.classList.add('active');
          });
        }

        // Fade out current slide, then unmount after transition
        if (prevSlide) {
          prevSlide.classList.remove('active');
          setTimeout(() => {
            prevSlide.classList.remove('mounted');
          }, 800);
        }

        // Crossfade background colour
        if (bgLayer) bgLayer.style.backgroundColor = bgColors[index];

        // Update accent colour on nav + header (chromatic restraint: only two voices)
        const accentColor = accentColors[index];
        if (slideNav) slideNav.style.color = accentColor;
        if (appHeader) appHeader.style.color = accentColor;

        // Show nav on all slides
        if (slideNav) {
          slideNav.style.display = 'flex';
          requestAnimationFrame(() => {
            slideNav.style.opacity = '1';
            slideNav.style.pointerEvents = 'auto';
          });
        }

        // Update active nav item
        slideNavItems.forEach((item, i) => {
          item.classList.toggle('active', i === index);
        });

        // Fade in next slide
        if (nextSlide) {
          nextSlide.classList.add('active');
        }

        currentSlide = index;
        setTimeout(() => {
          isTransitioning = false;
          hoverEnabled = true; // Re-enable hover after transition completes
        }, TRANSITION_LOCK_MS);
      }

      // ─── Wheel navigation ───
      let wheelAccum = 0;
      const WHEEL_THRESHOLD = 50;
      let wheelTimeout;

      window.addEventListener('wheel', (e) => {
        e.preventDefault();
        if (isTransitioning) return;

        wheelAccum += e.deltaY;

        clearTimeout(wheelTimeout);
        wheelTimeout = setTimeout(() => { wheelAccum = 0; }, 200);

        if (Math.abs(wheelAccum) >= WHEEL_THRESHOLD) {
          if (wheelAccum > 0) goToSlide(currentSlide + 1);
          else goToSlide(currentSlide - 1);
          wheelAccum = 0;
        }
      }, { passive: false });

      // ─── Arrow key navigation ───
      window.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
          e.preventDefault();
          goToSlide(currentSlide + 1);
        }
        if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
          e.preventDefault();
          goToSlide(currentSlide - 1);
        }
      });

      // ─── Click navigation (nav items, header links) ───
      document.querySelectorAll('[data-slide]').forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          goToSlide(parseInt(el.dataset.slide));
        });
      });

      // ─── Touch swipe (mobile) ───
      let touchStartY = 0;
      let touchStartX = 0;
      const SWIPE_THRESHOLD = 50;

      document.addEventListener('touchstart', (e) => {
        touchStartY = e.changedTouches[0].screenY;
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        const deltaY = touchStartY - e.changedTouches[0].screenY;
        const deltaX = touchStartX - e.changedTouches[0].screenX;

        // Only trigger if vertical swipe is dominant
        if (Math.abs(deltaY) > Math.abs(deltaX) && Math.abs(deltaY) > SWIPE_THRESHOLD) {
          if (deltaY > 0) goToSlide(currentSlide + 1);
          else goToSlide(currentSlide - 1);
        }
      }, { passive: true });

      // ─── Per-character hero animation ───
      function initHeroAnimation() {
        const name = 'Alister Maddrell';
        const solidEl = document.getElementById('hero-title-solid');
        const outlineEl = document.getElementById('hero-title-outline');
        if (!solidEl || !outlineEl) return;

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const buildChars = (text) => {
          return text.split('').map((char, i) => {
            const span = document.createElement('span');
            span.textContent = char === ' ' ? '\u00A0' : char;
            span.className = prefersReduced ? 'char-animate revealed' : 'char-animate';
            span.style.transitionDelay = `${i * 50}ms`;
            return span;
          });
        };

        const solidChars = buildChars(name);
        const outlineChars = buildChars(name);

        solidChars.forEach(c => solidEl.appendChild(c));
        outlineChars.forEach(c => outlineEl.appendChild(c));

        if (!prefersReduced) {
          requestAnimationFrame(() => {
            setTimeout(() => {
              solidChars.forEach(c => c.classList.add('revealed'));
              outlineChars.forEach(c => c.classList.add('revealed'));
            }, 300);
          });
        }
      }

      // ─── Card tilt effect (mouse-tracking, hero cards only) ───
      function initCardTilt() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const hasFineCursor = window.matchMedia('(pointer: fine)').matches;
        if (prefersReduced || !hasFineCursor) return;

        document.querySelectorAll('.hero-card.card-work').forEach((card) => {
          let bounds;

          card.addEventListener('mouseenter', () => {
            bounds = card.getBoundingClientRect();
            card.style.transition = 'box-shadow 0.3s ease, border-color 0.3s ease';
          }, { passive: true });

          card.addEventListener('mousemove', (e) => {
            if (!bounds) bounds = card.getBoundingClientRect();
            const x = (e.clientX - bounds.left) / bounds.width - 0.5;
            const y = (e.clientY - bounds.top) / bounds.height - 0.5;
            card.style.transform = `perspective(600px) rotateY(${x * 10}deg) rotateX(${-y * 10}deg) translateZ(5px)`;
          }, { passive: true });

          card.addEventListener('mouseleave', () => {
            card.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.5s ease, border-color 0.3s ease';
            card.style.transform = '';
          }, { passive: true });
        });
      }

      // ─── Showcase carousel (scroll/click/hover/swipe to cycle cards) ───
      let hoverEnabled = true;

      function initShowcaseCarousel() {
        document.querySelectorAll('.showcase-stack').forEach(stack => {
          const frames = stack.querySelectorAll('.showcase-frame');
          if (frames.length < 2) return;

          // Find the live preview iframe in the same slide
          const slide = stack.closest('.slide');
          const iframe = slide ? slide.querySelector('.live-preview-iframe') : null;
          const baseUrl = iframe ? iframe.dataset.baseUrl : '';
          const pages = iframe ? JSON.parse(iframe.dataset.pages || '[]') : [];

          let activeIndex = 1; // Start on center card
          let isLocked = false;
          const LOCK_MS = 600;

          function setActive(index) {
            if (isLocked || index === activeIndex || index < 0 || index >= frames.length) return;
            isLocked = true;

            activeIndex = index;

            // Update card styling
            frames.forEach(f => f.classList.remove('frame-active'));
            frames[activeIndex].classList.add('frame-active');

            // Update stack position
            stack.classList.remove('stack-pos-0', 'stack-pos-1', 'stack-pos-2');
            stack.classList.add(`stack-pos-${activeIndex}`);

            // Iframe continues scrolling unaffected by card changes

            setTimeout(() => { isLocked = false; }, LOCK_MS);
          }

          // Stop scrolling in this iframe
          function stopScroll() {
            if (iframe && iframe.contentWindow) {
              try { iframe.contentWindow.postMessage('stop-scroll', '*'); } catch(e) {}
            }
          }

          // Start scrolling in this iframe
          function startScroll() {
            if (iframe && iframe.contentWindow) {
              try { iframe.contentWindow.postMessage('start-scroll', '*'); } catch(e) {}
            }
          }

          // Reset to center card (called on slide enter)
          function resetToCenter() {
            activeIndex = 1;
            isLocked = false;
            frames.forEach(f => f.classList.remove('frame-active'));
            frames[1].classList.add('frame-active');
            stack.classList.remove('stack-pos-0', 'stack-pos-1', 'stack-pos-2');
            stack.classList.add('stack-pos-1');
            stopScroll();
          }

          // Called when slide becomes active
          function onSlideEnter() {
            resetToCenter();
            // Brief delay then start
            setTimeout(() => startScroll(), 200);
          }

          // Called when slide is left
          function onSlideLeave() {
            stopScroll();
          }

          // Store functions on the slide element
          if (slide) {
            slide._resetCarousel = onSlideEnter;
            slide._leaveCarousel = onSlideLeave;
          }

          // Init: center card active
          frames[1].classList.add('frame-active');
          stack.classList.add('stack-pos-1');

          // Click to select
          frames.forEach((frame, i) => {
            frame.addEventListener('click', (e) => {
              if (i !== activeIndex) {
                e.preventDefault();
                e.stopPropagation();
                setActive(i);
              }
            });
          });

          // Hover to select (mouseenter on non-active card) — disabled during transitions
          frames.forEach((frame, i) => {
            frame.addEventListener('mouseenter', () => {
              if (hoverEnabled && i !== activeIndex) setActive(i);
            }, { passive: true });
          });

          // Wheel to cycle within stack (stops page scroll propagation)
          let stackWheelAccum = 0;
          const STACK_WHEEL_THRESHOLD = 40;
          let stackWheelTimeout;

          stack.addEventListener('wheel', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (isLocked) return;

            stackWheelAccum += e.deltaY;
            clearTimeout(stackWheelTimeout);
            stackWheelTimeout = setTimeout(() => { stackWheelAccum = 0; }, 150);

            if (Math.abs(stackWheelAccum) >= STACK_WHEEL_THRESHOLD) {
              if (stackWheelAccum > 0) setActive(activeIndex + 1);
              else setActive(activeIndex - 1);
              stackWheelAccum = 0;
            }
          }, { passive: false });

          // Touch swipe on stack (mobile)
          let stackTouchStartY = 0;
          stack.addEventListener('touchstart', (e) => {
            stackTouchStartY = e.changedTouches[0].screenY;
          }, { passive: true });

          stack.addEventListener('touchend', (e) => {
            const deltaY = stackTouchStartY - e.changedTouches[0].screenY;
            if (Math.abs(deltaY) > 30) {
              if (deltaY > 0) setActive(activeIndex + 1);
              else setActive(activeIndex - 1);
            }
          }, { passive: true });
        });
      }

      // ─── Init ───
      document.addEventListener('DOMContentLoaded', () => {
        initHeroAnimation();
        initCardTilt();
        initShowcaseCarousel();
      });
    </script>
  </body>
</html>
