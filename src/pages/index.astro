---
import '../styles/global.css';
import palettes from '../data/palettes.json';

const projects = [
  {
    id: 'hartley',
    title: 'Hartley',
    description: 'Emergency-focused trade website with 24/7 lead capture, click-to-call, and service area mapping that converts urgent searches into booked jobs.',
    url: 'https://demo-hartley-plumbing.vercel.app',
    pages: ['/#services', '/', '/#contact'],
    image: '/thumbnails/hartley.webp',
    image2: '/thumbnails/hartley-2.webp',
    image3: '/thumbnails/hartley-3.webp',
  },
  {
    id: 'kin',
    title: 'Kin',
    description: 'Warm editorial hospitality site with interactive digital menu, event listings, email capture, and catering enquiries — a community hub that drives repeat visits.',
    url: 'https://demo-kin-grain-cafe.vercel.app',
    pages: ['/#menu', '/', '/#contact'],
    image: '/thumbnails/cafe.webp',
    image2: '/thumbnails/cafe-2.webp',
    image3: '/thumbnails/cafe-3.webp',
  },
  {
    id: 'apex',
    title: 'Apex',
    description: 'Conversion-optimised fitness site built as a sales funnel — multi-step lead capture, membership pricing, and urgency-driven CTAs that turn visitors into trial members.',
    url: 'https://demo-apex-fitness.vercel.app',
    pages: ['/#classes', '/', '/#contact'],
    image: '/thumbnails/fitness.webp',
    image2: '/thumbnails/fitness-2.webp',
    image3: '/thumbnails/fitness-3.webp',
  },
  {
    id: 'whitfield',
    title: 'W & A',
    description: 'Authority-driven professional services site with insights blog, consultation booking, animated credibility metrics, and content marketing architecture.',
    url: 'https://demo-whitfield-accounting.vercel.app',
    pages: ['/#insights', '/', '/#contact'],
    image: '/thumbnails/accounting.webp',
    image2: '/thumbnails/accounting-2.webp',
    image3: '/thumbnails/accounting-3.webp',
  },
  {
    id: 'luma',
    title: 'LUMA',
    description: 'Premium skincare e-commerce site with product filtering, detailed product pages, size selectors, and a polished add-to-bag flow — warm luxury that drives conversions.',
    url: 'https://demo-luma-beauty.vercel.app',
    pages: ['/shop', '/', '/about'],
    image: '/thumbnails/beauty.webp',
    image2: '/thumbnails/beauty-2.webp',
    image3: '/thumbnails/beauty-3.webp',
  },
  {
    id: 'flowline',
    title: 'Flowline',
    description: 'Dark-mode SaaS landing page with gradient mesh hero, tabbed product showcase, tiered pricing, and social proof — built for sign-ups.',
    url: 'https://demo-flowline-saas.vercel.app',
    pages: ['/#features', '/', '/#pricing'],
    image: '/thumbnails/saas.webp',
    image2: '/thumbnails/saas-2.webp',
    image3: '/thumbnails/saas-3.webp',
  },
  {
    id: 'evergreen',
    title: 'Evergreen',
    description: 'Romantic editorial wedding & event planning site with filterable portfolio, lightbox gallery, service packages, and an elegant multi-field enquiry form.',
    url: 'https://demo-evergreen-events.vercel.app',
    pages: ['/portfolio', '/', '/services'],
    image: '/thumbnails/events.webp',
    image2: '/thumbnails/events-2.webp',
    image3: '/thumbnails/events-3.webp',
  },
].map(p => ({
  ...p,
  bg: palettes[p.id].background,
  accent: palettes[p.id].accent,
  text: palettes[p.id].text,
}));

// Hero and contact get their own palette
const heroBg = '#491FAD';
const heroAccent = '#FBBF24';
const contactBg = '#1E1B4B';
const contactAccent = '#A78BFA';

const bgColors = [heroBg, ...projects.map(p => p.bg), contactBg];
const accentColors = [heroAccent, ...projects.map(p => p.accent), contactAccent];

const navItems = [
  { label: 'Home', slideIndex: 0 },
  ...projects.map((p, i) => ({ label: p.title, slideIndex: i + 1 })),
  { label: 'Contact', slideIndex: projects.length + 1 },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Alister Maddrell — Web Designer & Developer based in Sydney. Custom-built, high-performance websites for local businesses." />
    <meta property="og:title" content="Alister Maddrell — Web Designer & Developer" />
    <meta property="og:description" content="Custom-built, high-performance websites for Sydney businesses." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://portfolio-alt-alister-maddrell.vercel.app/thumbnails/hartley.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href="https://portfolio-alt-alister-maddrell.vercel.app/" />
    <title>Alister Maddrell — Web Designer & Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <a href="#slide-0" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded">Skip to content</a>
    <div id="app" class="relative w-full h-screen overflow-hidden">
      <!-- ═══════════════════════════════════════ -->
      <!-- BACKGROUND LAYER                       -->
      <!-- ═══════════════════════════════════════ -->
      <div id="bg-layer" class="absolute inset-0" style={`background-color: ${heroBg};`}></div>

      <!-- ═══════════════════════════════════════ -->
      <!-- FIXED HEADER — always visible          -->
      <!-- ═══════════════════════════════════════ -->
      <header id="app-header" class="absolute top-0 left-0 w-full h-[90px] pr-[6.25%] pl-[calc(6.25%+16px)] flex items-center justify-between z-30 transition-colors duration-600" style={`color: ${heroAccent};`}>
        <a href="#" class="ui-text ui-text-sm flex items-center min-h-[44px]" data-slide="0">Alister Maddrell</a>
        <a href="#" class="ui-text ui-text-sm hover:opacity-70 transition-opacity duration-200 flex items-center min-h-[44px]" data-slide="8">Contact</a>
      </header>

      <!-- ═══════════════════════════════════════ -->
      <!-- SLIDE 0: HERO                          -->
      <!-- ═══════════════════════════════════════ -->
      <section id="slide-0" class="slide active" style={`--slide-accent: ${heroAccent}; background-color: ${heroBg};`}>
        <div class="accent-bar" style={`background-color: ${heroAccent};`}></div>
        <div class="hero-layout">
          <!-- Left: name + role + CTAs -->
          <div class="hero-left">
            <div class="hero-content">
              <div class="relative slide-title">
                <h1 id="hero-title-solid" class="hero-name title-solid" style={`color: ${heroAccent};`}></h1>
                <div id="hero-title-outline" class="hero-name title-outline absolute inset-0" style={`-webkit-text-stroke-color: ${heroAccent};`} aria-hidden="true"></div>
              </div>
              <p class="ui-text ui-text-sm mt-4 slide-desc" style={`color: ${heroAccent}; letter-spacing: 3px; opacity: 0.8;`}>Web Designer &amp; Developer · Sydney</p>
              <p class="desc-text mt-6 slide-desc" style="color: #ffffff; max-width: 400px;">I design and build conversion-focused websites for small businesses — clean, fast, and built to turn visitors into customers.</p>
              <div class="flex gap-4 mt-8 slide-cta">
                <a href="#" class="hero-cta-primary ui-text ui-text-md" data-slide="1" style={`color: ${heroAccent}; border-color: ${heroAccent};`}>
                  <span>View My Work</span>
                  <span class="cta-arrow">&rarr;</span>
                </a>
                <a href="#" class="cta-link ui-text ui-text-md" data-slide="8" style={`color: ${heroAccent};`}>
                  <span>Get in Touch</span>
                  <span class="cta-arrow">&rarr;</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Right: featured project card -->
          <div class="hero-right slide-image" style="perspective: 800px;">
            <div class="hero-featured">
              <div id="hero-card" class="hero-featured-card card-work" style={`--card-color: ${heroAccent};`}>
                <div class="card-work-topbar">
                  <span class="card-work-dots" aria-hidden="true">
                    <span></span><span></span><span></span>
                  </span>
                  <div class="card-work-urlbar">
                    <svg class="card-work-globe" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M1 8h14M8 1c-2.5 3-2.5 9 0 14M8 1c2.5 3 2.5 9 0 14" stroke="currentColor" stroke-width="1.2"/></svg>
                    <span id="hero-card-url" class="card-work-url"><span class="card-work-url-proto">https://</span> {projects[0].title.toLowerCase()}.com.au</span>
                  </div>
                  <span class="card-work-capsule" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6.66667M12 4V9.33333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
                <div class="card-work-img" style="position: relative;">
                  {projects.map((project, i) => (
                    <img
                      class={`hero-card-image ${i === 0 ? 'active' : ''}`}
                      data-hero-img={i}
                      src={project.image}
                      alt={`${project.title} preview`}
                      width="1440"
                      height="900"
                      loading="eager"
                      decoding="async"
                    />
                  ))}
                </div>
              </div>
              <!-- Project count strip -->
              <div class="hero-project-strip" id="hero-strip">
                {projects.map((project, i) => (
                  <button class={`hero-strip-item ${i === 0 ? 'active' : ''}`} data-slide={i + 1} data-hero-index={i} style={`--strip-color: ${project.accent};`}>
                    <span class="hero-strip-dot"></span>
                    <span class="hero-strip-label">{project.title}</span>
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════ -->
      <!-- SLIDES 1-5: PROJECTS                   -->
      <!-- ═══════════════════════════════════════ -->
      {projects.map((project, i) => {
        const slideIndex = i + 1;
        return (
          <section id={`slide-${slideIndex}`} class="slide" data-slide-index={slideIndex} style={`--slide-accent: ${project.accent}; background-color: ${project.bg};`}>
            <!-- Accent bar -->
            <div class="accent-bar" style={`background-color: ${project.accent};`}></div>

            <div class="showcase-layout" style={`color: ${project.text};`}>
              <!-- Left column: content + live preview, evenly spaced -->
              <div class="showcase-left">
                <div class="showcase-content">
                  <h2 class="title-display title-project slide-title" style={`color: ${project.accent};`}>
                    {project.title}
                  </h2>
                  <p class="desc-text mt-6 slide-desc">
                    {project.description}
                  </p>
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="cta-link ui-text ui-text-md mt-[34px] slide-cta"
                    style={`color: ${project.accent};`}
                  >
                    <span>View Live Site</span>
                    <span class="cta-arrow">&rarr;</span>
                  </a>
                </div>
                <div class="live-preview hidden lg:block" style={`--card-color: ${project.accent}; border-color: ${project.accent};`}>
                  <div class="card-work-topbar card-work-topbar--mini">
                    <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                      <span></span><span></span><span></span>
                    </span>
                    <div class="card-work-urlbar card-work-urlbar--mini">
                      <span class="card-work-url">{project.title}</span>
                    </div>
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="card-work-capsule card-work-capsule--mini" aria-label={`Visit ${project.title}`}>
                      <svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6.66667M12 4V9.33333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                  </div>
                  <div class="live-preview-viewport">
                    <iframe
                      class="live-preview-iframe"
                      data-base-url={project.url}
                      data-pages={JSON.stringify(project.pages)}
                      src={`${project.url}?preview`}
                      title={`${project.title} live preview`}
                      loading="eager"
                      sandbox="allow-scripts allow-same-origin"
                    ></iframe>
                  </div>
                </div>
              </div>

              <!-- Center: Stacked screenshots -->
              <div class="showcase-cards slide-image" style="perspective: 800px;">
                <div class="showcase-stack" style={`--card-color: ${project.accent};`}>
                  <!-- Page 2 (top slot) -->
                  <div class="showcase-frame">
                    <div class="card-work-topbar card-work-topbar--mini">
                      <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                        <span></span><span></span><span></span>
                      </span>
                      <div class="card-work-urlbar card-work-urlbar--mini">
                        <span class="card-work-url">{project.title}</span>
                      </div>
                      <a href={`${project.url}${project.pages[0]}`} target="_blank" rel="noopener noreferrer" class="card-work-capsule card-work-capsule--mini" aria-label={`Visit ${project.title}`}>
                        <svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6.66667M12 4V9.33333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                    </div>
                    <div class="card-work-img">
                      <img src={project.image2} alt={`${project.title} page 2`} width="1440" height="900" loading="eager" decoding="async" />
                    </div>
                  </div>
                  <!-- Landing page (center slot, flush) -->
                  <div class="showcase-frame">
                    <div class="card-work-topbar card-work-topbar--mini">
                      <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                        <span></span><span></span><span></span>
                      </span>
                      <div class="card-work-urlbar card-work-urlbar--mini">
                        <span class="card-work-url">{project.title}</span>
                      </div>
                      <a href={project.url} target="_blank" rel="noopener noreferrer" class="card-work-capsule card-work-capsule--mini" aria-label={`Visit ${project.title}`}>
                        <svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6.66667M12 4V9.33333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                    </div>
                    <div class="card-work-img">
                      <img src={project.image} alt={`${project.title} homepage`} width="1440" height="900" loading="eager" decoding="async" />
                    </div>
                  </div>
                  <!-- Page 3 (bottom slot) -->
                  <div class="showcase-frame">
                    <div class="card-work-topbar card-work-topbar--mini">
                      <span class="card-work-dots card-work-dots--mini" aria-hidden="true">
                        <span></span><span></span><span></span>
                      </span>
                      <div class="card-work-urlbar card-work-urlbar--mini">
                        <span class="card-work-url">{project.title}</span>
                      </div>
                      <a href={`${project.url}${project.pages[2]}`} target="_blank" rel="noopener noreferrer" class="card-work-capsule card-work-capsule--mini" aria-label={`Visit ${project.title}`}>
                        <svg viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6.66667M12 4V9.33333" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                    </div>
                    <div class="card-work-img">
                      <img src={project.image3} alt={`${project.title} page 3`} width="1440" height="900" loading="eager" decoding="async" />
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </section>
        );
      })}

      <!-- ═══════════════════════════════════════ -->
      <!-- SLIDE 6: ABOUT / CONTACT               -->
      <!-- ═══════════════════════════════════════ -->
      <section id="slide-8" class="slide" data-slide-index="8" style={`--slide-accent: ${contactAccent}; background-color: ${contactBg};`}>
        <div class="accent-bar" style={`background-color: ${contactAccent};`}></div>
        <div class="showcase-layout" style={`color: #ffffff;`}>
          <!-- Left column: title + info -->
          <div class="showcase-left">
            <div class="showcase-content">
              <p class="ui-text ui-text-sm slide-desc" style={`color: ${contactAccent}; letter-spacing: 3px; opacity: 0.8;`}>Get in Touch</p>
              <h2 class="title-display title-project mt-4 slide-title" style={`color: ${contactAccent};`}>
                Let's Work<br/>Together
              </h2>
              <p class="desc-text mt-6 slide-desc" style="opacity: 0.7;">
                I design and build fast, modern websites for local businesses across Sydney. Every site is custom-built, SEO-optimised, and designed to turn visitors into customers.
              </p>
              <div class="flex flex-col gap-3 mt-8 slide-cta">
                <a href="mailto:alistermaddrell@gmail.com" class="cta-link ui-text ui-text-md" style={`color: ${contactAccent};`}>
                  <span>alistermaddrell@gmail.com</span>
                  <span class="cta-arrow">&rarr;</span>
                </a>
              </div>
            </div>
            <p class="ui-text ui-text-sm slide-meta" style={`color: ${contactAccent}; opacity: 0.5;`}>Sydney, Australia</p>
          </div>

          <!-- Right column: form in browser chrome card -->
          <div class="contact-right slide-image">
            <div class="contact-form-card" style={`--card-color: ${contactAccent};`}>
              <div class="card-work-topbar">
                <span class="card-work-dots" aria-hidden="true">
                  <span></span><span></span><span></span>
                </span>
                <div class="card-work-urlbar">
                  <svg class="card-work-globe" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M1 8h14M8 1c-2.5 3-2.5 9 0 14M8 1c2.5 3 2.5 9 0 14" stroke="currentColor" stroke-width="1.2"/></svg>
                  <span class="card-work-url"><span class="card-work-url-proto">mailto:</span> alistermaddrell@gmail.com</span>
                </div>
              </div>
              <div class="contact-form-body">
                <form action="https://formspree.io/f/mlgplaev" method="POST" class="space-y-6">
                  <div>
                    <label for="name" class="ui-text text-xs block mb-2" style={`letter-spacing: 1px; color: ${contactAccent};`}>Name</label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      placeholder="Your name"
                      class="contact-input"
                      style={`--accent: ${contactAccent};`}
                    />
                  </div>
                  <div>
                    <label for="email" class="ui-text text-xs block mb-2" style={`letter-spacing: 1px; color: ${contactAccent};`}>Email</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      placeholder="you@example.com"
                      class="contact-input"
                      style={`--accent: ${contactAccent};`}
                    />
                  </div>
                  <div>
                    <label for="message" class="ui-text text-xs block mb-2" style={`letter-spacing: 1px; color: ${contactAccent};`}>Message</label>
                    <textarea
                      id="message"
                      name="message"
                      rows="5"
                      required
                      placeholder="Tell me about your project..."
                      class="contact-input resize-none"
                      style={`--accent: ${contactAccent};`}
                    ></textarea>
                  </div>
                  <button
                    type="submit"
                    class="contact-submit ui-text ui-text-md"
                    style={`background: ${contactAccent}; color: ${contactBg};`}
                  >
                    <span>Send Message</span>
                    <span class="cta-arrow">&rarr;</span>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════ -->
      <!-- UNIFIED SLIDE NAV                      -->
      <!-- ═══════════════════════════════════════ -->
      <nav id="slide-nav" class="slide-nav z-40 transition-opacity duration-500" style={`color: ${heroAccent};`}>
        <div class="slide-nav-inner">
          {navItems.map((item, i) => (
            <button class={`slide-nav-item ${i === 0 ? 'active' : ''}`} data-slide={item.slideIndex} aria-label={`Go to ${item.label}`}>
              <span class="slide-nav-label">{item.label}</span>
              <span class="slide-nav-dot"></span>
            </button>
          ))}
        </div>
      </nav>

      <!-- Scroll indicator -->
      <div id="scroll-indicator" class="scroll-indicator-wrap" style={`color: ${heroAccent};`}>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 4L10 16M10 16L5 11M10 16L15 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <!-- ═══════════════════════════════════════ -->
    <!-- CLIENT-SIDE JS                         -->
    <!-- ═══════════════════════════════════════ -->
    <script define:vars={{ bgColors, accentColors }}>
      // ─── State ───
      let currentSlide = 0;
      const totalSlides = 9;
      let isTransitioning = false;
      let wheelUnlockTimer = null;

      // ─── DOM refs ───
      const bgLayer = document.getElementById('bg-layer');
      const appHeader = document.getElementById('app-header');
      const slideNav = document.getElementById('slide-nav');
      const slideNavItems = document.querySelectorAll('#slide-nav .slide-nav-item');
      const scrollIndicator = document.getElementById('scroll-indicator');

      // ─── Go to slide ───
      function goToSlide(index) {
        if (isTransitioning || index === currentSlide || index < 0 || index >= totalSlides) return;
        isTransitioning = true;
        hoverEnabled = false;

        const prevSlide = document.getElementById(`slide-${currentSlide}`);
        const nextSlide = document.getElementById(`slide-${index}`);
        const goingDown = index > currentSlide;

        // Carousel housekeeping
        if (prevSlide && prevSlide._leaveCarousel) prevSlide._leaveCarousel();
        if (nextSlide && nextSlide._resetCarousel) nextSlide._resetCarousel();

        // Exit previous — instant hide
        if (prevSlide) {
          prevSlide.classList.remove('active');
          prevSlide.classList.add(goingDown ? 'slide-exit-up' : 'slide-exit-down');
          setTimeout(() => {
            prevSlide.classList.remove('slide-exit-up', 'slide-exit-down');
          }, 750);
        }

        // Enter new slide — double-rAF for paint-then-animate
        if (nextSlide) {
          nextSlide.classList.remove('slide-exit-up', 'slide-exit-down', 'active');
          nextSlide.classList.add(goingDown ? 'slide-enter-from-below' : 'slide-enter-from-above');
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              nextSlide.classList.remove('slide-enter-from-below', 'slide-enter-from-above');
              nextSlide.classList.add('active');
            });
          });
        }

        // Crossfade background colour
        if (bgLayer) bgLayer.style.backgroundColor = bgColors[index];

        // Update accent colour on nav, header, scroll indicator
        const accentColor = accentColors[index];
        if (slideNav) slideNav.style.color = accentColor;
        if (appHeader) appHeader.style.color = accentColor;
        if (scrollIndicator) scrollIndicator.style.color = accentColor;

        // Update active nav item
        slideNavItems.forEach((item, i) => {
          item.classList.toggle('active', i === index);
        });

        currentSlide = index;

        // Unlock after 600ms (for arrow keys / nav clicks).
        // Wheel handler will extend this lock while inertia events arrive.
        clearTimeout(wheelUnlockTimer);
        wheelUnlockTimer = setTimeout(() => {
          isTransitioning = false;
          hoverEnabled = true;
        }, 600);
      }

      // ─── Wheel navigation ───
      let wheelAccum = 0;
      const WHEEL_THRESHOLD = 80;
      let wheelTimeout;

      window.addEventListener('wheel', (e) => {
        const tag = e.target.tagName;
        if (tag === 'TEXTAREA' || tag === 'SELECT') return;
        e.preventDefault();

        if (isTransitioning) {
          wheelAccum = 0;
          // Inertia still arriving — push unlock back by 200ms each time
          clearTimeout(wheelUnlockTimer);
          wheelUnlockTimer = setTimeout(() => {
            isTransitioning = false;
            hoverEnabled = true;
          }, 200);
          return;
        }

        wheelAccum += e.deltaY;

        clearTimeout(wheelTimeout);
        wheelTimeout = setTimeout(() => { wheelAccum = 0; }, 150);

        if (Math.abs(wheelAccum) >= WHEEL_THRESHOLD) {
          if (wheelAccum > 0) goToSlide(currentSlide + 1);
          else goToSlide(currentSlide - 1);
          wheelAccum = 0;
        }
      }, { passive: false });

      // ─── Arrow key navigation ───
      window.addEventListener('keydown', (e) => {
        // Don't intercept arrows inside form fields
        const tag = document.activeElement?.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;

        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
          e.preventDefault();
          goToSlide(currentSlide + 1);
        }
        if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
          e.preventDefault();
          goToSlide(currentSlide - 1);
        }
      });

      // ─── Click navigation (nav items, header links) ───
      document.querySelectorAll('[data-slide]').forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          goToSlide(parseInt(el.dataset.slide));
        });
      });

      // ─── Touch swipe (mobile) ───
      let touchStartY = 0;
      let touchStartX = 0;
      const SWIPE_THRESHOLD = 50;

      document.addEventListener('touchstart', (e) => {
        touchStartY = e.changedTouches[0].screenY;
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        const deltaY = touchStartY - e.changedTouches[0].screenY;
        const deltaX = touchStartX - e.changedTouches[0].screenX;

        // Only trigger if vertical swipe is dominant
        if (Math.abs(deltaY) > Math.abs(deltaX) && Math.abs(deltaY) > SWIPE_THRESHOLD) {
          if (deltaY > 0) goToSlide(currentSlide + 1);
          else goToSlide(currentSlide - 1);
        }
      }, { passive: true });

      // ─── Per-character hero animation ───
      function initHeroAnimation() {
        const name = 'My Work';
        const solidEl = document.getElementById('hero-title-solid');
        const outlineEl = document.getElementById('hero-title-outline');
        if (!solidEl || !outlineEl) return;

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const buildChars = (text) => {
          return text.split('').map((char, i) => {
            if (char === ' ') {
              const br = document.createElement('br');
              return br;
            }
            const span = document.createElement('span');
            span.textContent = char;
            span.className = prefersReduced ? 'char-animate revealed' : 'char-animate';
            span.style.transitionDelay = `${i * 50}ms`;
            return span;
          });
        };

        const solidChars = buildChars(name);
        const outlineChars = buildChars(name);

        solidChars.forEach(c => solidEl.appendChild(c));
        outlineChars.forEach(c => outlineEl.appendChild(c));

        if (!prefersReduced) {
          requestAnimationFrame(() => {
            setTimeout(() => {
              solidChars.forEach(c => c.classList && c.classList.add('revealed'));
              outlineChars.forEach(c => c.classList && c.classList.add('revealed'));
            }, 300);
          });
        }
      }

      // ─── Hero strip — hover to change featured card ───
      function initHeroStrip() {
        const strip = document.getElementById('hero-strip');
        const card = document.getElementById('hero-card');
        const urlEl = document.getElementById('hero-card-url');
        if (!strip || !card) return;

        const items = strip.querySelectorAll('.hero-strip-item');
        const images = card.querySelectorAll('.hero-card-image');
        const titles = [].map.call(items, el => el.querySelector('.hero-strip-label')?.textContent?.toLowerCase() || '');
        let currentHeroIndex = 0;
        let urlAnimId = null;

        function typeUrl(newDomain) {
          if (urlAnimId) clearInterval(urlAnimId);
          const prefix = '<span class="card-work-url-proto">https://</span> ';
          const fullNew = newDomain + '.com.au';
          // Get current text (strip HTML)
          const tmp = document.createElement('span');
          tmp.innerHTML = urlEl.innerHTML;
          const currentText = tmp.textContent.trim();
          const cursor = '<span class="hero-url-cursor"></span>';

          let phase = 'delete';
          let deleteText = currentText;
          let typeIndex = 0;

          urlAnimId = setInterval(() => {
            if (phase === 'delete') {
              if (deleteText.length > 0) {
                deleteText = deleteText.slice(0, -1);
                urlEl.innerHTML = prefix + deleteText + cursor;
              } else {
                phase = 'type';
              }
            } else {
              if (typeIndex <= fullNew.length) {
                urlEl.innerHTML = prefix + fullNew.slice(0, typeIndex) + cursor;
                typeIndex++;
              } else {
                urlEl.innerHTML = prefix + fullNew;
                clearInterval(urlAnimId);
                urlAnimId = null;
              }
            }
          }, 25);
        }

        items.forEach((item, i) => {
          item.addEventListener('mouseenter', () => {
            if (i === currentHeroIndex) return;
            const prevIndex = currentHeroIndex;

            // Update strip active state
            items.forEach(it => it.classList.remove('active'));
            item.classList.add('active');

            // Slide image transition (directional)
            const goingDown = i > prevIndex;
            const prevImg = images[prevIndex];
            const nextImg = images[i];
            const exitClass = goingDown ? 'exit-up' : 'exit-down';
            const enterClass = goingDown ? 'enter-from-below' : 'enter-from-above';

            // Exit old image
            if (prevImg) {
              prevImg.classList.remove('active', 'enter-from-below', 'enter-from-above');
              prevImg.classList.add(exitClass);
              setTimeout(() => prevImg.classList.remove('exit-up', 'exit-down'), 600);
            }

            // Enter new image
            if (nextImg) {
              nextImg.classList.remove('active', 'exit-up', 'exit-down');
              nextImg.classList.add(enterClass);
              requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                  nextImg.classList.remove('enter-from-below', 'enter-from-above');
                  nextImg.classList.add('active');
                });
              });
            }

            // Typing URL animation
            typeUrl(titles[i]);

            currentHeroIndex = i;
          }, { passive: true });
        });
      }

      // ─── Showcase carousel (scroll/click/hover/swipe to cycle cards) ───
      let hoverEnabled = true;

      function initShowcaseCarousel() {
        document.querySelectorAll('.showcase-stack').forEach(stack => {
          const frames = stack.querySelectorAll('.showcase-frame');
          if (frames.length < 2) return;

          // Find the live preview iframe in the same slide
          const slide = stack.closest('.slide');
          const iframe = slide ? slide.querySelector('.live-preview-iframe') : null;
          const baseUrl = iframe ? iframe.dataset.baseUrl : '';
          const pages = iframe ? JSON.parse(iframe.dataset.pages || '[]') : [];

          let activeIndex = 1; // Start on center card
          let isLocked = false;
          const LOCK_MS = 600;

          function setActive(index) {
            if (isLocked || index === activeIndex || index < 0 || index >= frames.length) return;
            isLocked = true;

            activeIndex = index;

            // Update card styling
            frames.forEach(f => f.classList.remove('frame-active'));
            frames[activeIndex].classList.add('frame-active');

            // Update stack position
            stack.classList.remove('stack-pos-0', 'stack-pos-1', 'stack-pos-2');
            stack.classList.add(`stack-pos-${activeIndex}`);

            // Iframe continues scrolling unaffected by card changes

            setTimeout(() => { isLocked = false; }, LOCK_MS);
          }

          // Stop scrolling in this iframe
          function stopScroll() {
            if (iframe && iframe.contentWindow) {
              try { iframe.contentWindow.postMessage('stop-scroll', '*'); } catch(e) {}
            }
          }

          // Start scrolling in this iframe
          function startScroll() {
            if (iframe && iframe.contentWindow) {
              try { iframe.contentWindow.postMessage('start-scroll', '*'); } catch(e) {}
            }
          }

          // Reset to center card (called on slide enter)
          function resetToCenter() {
            activeIndex = 1;
            isLocked = false;
            frames.forEach(f => f.classList.remove('frame-active'));
            frames[1].classList.add('frame-active');
            stack.classList.remove('stack-pos-0', 'stack-pos-1', 'stack-pos-2');
            stack.classList.add('stack-pos-1');
            stopScroll();
          }

          // Called when slide becomes active
          function onSlideEnter() {
            resetToCenter();
            // Brief delay then start
            setTimeout(() => startScroll(), 200);
          }

          // Called when slide is left
          function onSlideLeave() {
            stopScroll();
          }

          // Store functions on the slide element
          if (slide) {
            slide._resetCarousel = onSlideEnter;
            slide._leaveCarousel = onSlideLeave;
          }

          // Init: center card active
          frames[1].classList.add('frame-active');
          stack.classList.add('stack-pos-1');

          // Click to select
          frames.forEach((frame, i) => {
            frame.addEventListener('click', (e) => {
              if (i !== activeIndex) {
                e.preventDefault();
                e.stopPropagation();
                setActive(i);
              }
            });
          });

          // Hover to select (mouseenter on non-active card) — disabled during transitions
          frames.forEach((frame, i) => {
            frame.addEventListener('mouseenter', () => {
              if (hoverEnabled && i !== activeIndex) setActive(i);
            }, { passive: true });
          });

          // Wheel to cycle within stack (stops page scroll propagation)
          let stackWheelAccum = 0;
          const STACK_WHEEL_THRESHOLD = 50;

          stack.addEventListener('wheel', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (isLocked) {
              stackWheelAccum = 0;
              return;
            }

            stackWheelAccum += e.deltaY;

            if (Math.abs(stackWheelAccum) >= STACK_WHEEL_THRESHOLD) {
              if (stackWheelAccum > 0) setActive(activeIndex + 1);
              else setActive(activeIndex - 1);
              stackWheelAccum = 0;
            }
          }, { passive: false });

          // Touch swipe on stack (mobile)
          let stackTouchStartY = 0;
          stack.addEventListener('touchstart', (e) => {
            stackTouchStartY = e.changedTouches[0].screenY;
          }, { passive: true });

          stack.addEventListener('touchend', (e) => {
            const deltaY = stackTouchStartY - e.changedTouches[0].screenY;
            if (Math.abs(deltaY) > 30) {
              if (deltaY > 0) setActive(activeIndex + 1);
              else setActive(activeIndex - 1);
            }
          }, { passive: true });
        });
      }

      // ─── Fit project titles to column width ───
      function fitProjectTitles() {
        if (window.innerWidth < 1024) return;
        document.querySelectorAll('.showcase-left .title-project').forEach(title => {
          const container = title.closest('.showcase-content') || title.parentElement;
          const maxW = container.clientWidth;
          // Reset to base size then scale down if needed
          title.style.fontSize = '';
          let size = parseFloat(getComputedStyle(title).fontSize);
          while (title.scrollWidth > maxW && size > 40) {
            size -= 2;
            title.style.fontSize = size + 'px';
          }
        });
      }

      // ─── Init ───
      document.addEventListener('DOMContentLoaded', () => {
        initHeroAnimation();
        initHeroStrip();
        initShowcaseCarousel();
        fitProjectTitles();
        window.addEventListener('resize', fitProjectTitles);
      });
    </script>
  </body>
</html>
